{
    "name": "nuxt-enterprise-template",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "prisma generate && node scripts/setup-db.mjs && nuxt dev",
        "generate": "nuxt generate",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "prepare": "node -e \"const fs=require('node:fs'); const cp=require('node:child_process'); if(fs.existsSync('.git')){cp.execSync('npx husky',{stdio:'inherit'});} else {console.log('Skipping Husky install: .git directory not found');}\"",
        "nuxt:prepare": "nuxt prepare",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "prisma db seed",
        "prisma:studio": "prisma studio",
        "preview": "nuxt preview"
    },
    "lint-staged": {
        "*.{js,ts,vue,mjs,cjs,css,md,json,yml,yaml}": "prettier --write"
    },
    "dependencies": {
        "@fontsource/poppins": "^5.2.7",
        "@lucide/vue": "^1.17.0",
        "@pinia/nuxt": "^0.11.3",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@supabase/supabase-js": "^2.106.1",
        "@tanstack/vue-query": "^5.100.11",
        "axios": "^1.16.1",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "joi": "^18.2.1",
        "jsonwebtoken": "^9.0.3",
        "nuxt": "^4.4.6",
        "pg": "^8.21.0",
        "pinia": "^3.0.4",
        "radix-vue": "^1.9.17",
        "tailwind-merge": "^3.6.0",
        "vue": "^3.5.34",
        "vue-router": "^5.0.7",
        "vue-sonner": "^2.0.9"
    },
    "devDependencies": {
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/eslint-config": "^1.15.2",
        "@nuxtjs/tailwindcss": "^6.14.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "prisma": "^7.8.0",
        "tailwindcss-animate": "^1.0.7"
    }
}
