# Database (PostgreSQL)
# Local example:
DATABASE_URL=postgresql://postgres:12345678@localhost:5432/elim_db

# JWT secret (minimum 32 characters)
JWT_SECRET=replace_this_with_a_long_random_secret_32_chars_min

# App server
PORT=3000
NODE_ENV=development

# Public runtime config
NUXT_PUBLIC_APP_NAME=Elim
